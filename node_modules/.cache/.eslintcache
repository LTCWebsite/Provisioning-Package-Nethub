1@hotmail.com\" />\n                    <input type=\"hidden\" name=\"password\" value=\"51d5985e\" />\n                    <input type=\"submit\" value={name} className=\"link-btn list\" />\n                </form>\n            </>\n        } else if (id === '28') {\n            return <>\n                <form method='GET' action='https://10.40.67.119:8443/explorer/login' target='_blank'>\n                    <input type={\"submit\"} value={name} className=\"link-btn list\" />\n                </form>\n            </>\n        } else if (id === '29') {\n            return <>\n                <form method='GET' action='http://10.0.10.201:8080' target='_blank'>\n                    <input type={\"submit\"} value={name} className=\"link-btn list\" />\n                </form>\n            </>\n        } else if (id === '30') {\n            return <>\n                <form method='GET' action='https://192.168.207.146:31943/unisso/login.action?service=%2Funisess%2Fv1%2Fauth%3Fservice%3D%252Fncecommonwebsite%252Fv1%252Fnewportal%252Findex.html%253Frefr-flags%253De' target='_blank'>\n                    <input type={\"submit\"} value={name} className=\"link-btn list\" />\n                </form>\n            </>\n        } else if (id === '31') {\n            return <>\n                <form method='POST' action='http://www.sod.laotel.com/wp-login.php' target='_blank'>\n                    <input name=\"log\" type=\"hidden\" value={topData[30]?.Username} />\n                    <input name=\"pwd\" type=\"hidden\" value={topData[30]?.Password} />\n                    <input name=\"wp-submit\" type=\"hidden\" value=\"Log In\" />\n                    <input name=\"redirect_to\" type=\"hidden\" value=\"http://www.sod.laotel.com\" />\n                    <input name=\"testcookie\" type=\"hidden\" value=\"1\" />\n                    <input type={\"submit\"} value={name} className=\"link-btn list\" />\n                </form>\n            </>\n        } else if (id === '32') {\n            return <>\n                <form method='GET' action='http://10.30.6.98:5152/Account/Login?ReturnUrl=%2FHome%2FRerun' target='_blank'>\n                    <input type={\"submit\"} value={name} className=\"link-btn list\" />\n                </form>\n            </>\n        } else if (id === '33') {\n            return <>\n                <form name=\"Loggingin\" action=\"https://secure.gameloft.com/supporttool/index.php?module=Search\" method=\"GET\" target='_blank'>\n                    <input type=\"submit\" className='link-btn list' value={name} />\n                </form>\n            </>\n        } else if (id === '34') {\n            return <>\n                <form name=\"Loggingin\" action=\"https://sp.openlife.huawei.com:31943\" method=\"GET\" target='_blank'>\n                    <input type=\"submit\" className='link-btn list' value={name} />\n                </form>\n            </>\n        } else if (id === '35') {\n            return <>\n                <form name=\"Loggingin\" action=\"http://115.84.121.37/\" method=\"GET\" target='_blank'>\n                    <input type=\"submit\" className='link-btn list' value={name} />\n                </form>\n            </>\n        } else if (id === '36') {\n            return <>\n                <form name=\"Loggingin\" action=\"http://10.30.6.48:8080/POS\" method=\"GET\" target='_blank'>\n                    <input type=\"submit\" className='link-btn list' value={name} />\n                </form>\n            </>\n        } else {\n            return <>{name}</>\n        }\n    }\n\n    return (\n        <>\n            <div className='frame'>\n                {topData.data.map((row, idx) => {\n                    return (\n                        <div className={idx === 0 ? 'list' : 'list'} key={idx}><FadeIn>\n                            <LinkList id={row.ID} name={row.Name} />\n                        </FadeIn></div>\n                    )\n                })}\n            </div>\n        </>\n    )\n}\n\nexport default TopBar","/Users/joebest/Desktop/Github/1Screen/src/Pages/App/Router.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/CRM/CRM.jsx",["167"],"import { Grid } from '@mui/material'\nimport React, { useEffect, useState } from 'react'\nimport { AxiosReq } from '../../../Components/Axios'\nimport Crypt from '../../../Components/Crypt'\nimport Col1 from './Col1'\nimport Col2 from './Col2'\nimport { useHistory } from 'react-router-dom'\nimport { toast_error } from '../../../Components/Toast'\n\nfunction CRM() {\n  const [ready, setReady] = useState({ load: false })\n  const history = useHistory()\n\n  useEffect(() => {\n    try {\n      let phone = localStorage.getItem(\"ONE_PHONE\")\n      if (phone.length <= 0) {\n        toast_error({ text: \"ກະລຸນາປ້ອນເບີ !!\" })\n        history.push(\"/app\")\n      } else {\n        setReady({ ...ready, load: true })\n        AxiosReq.get(\"NewNetworkType?msisdn=\" + phone).then(res => {\n          if (res.status === 200) {\n            // console.log(res.data)\n            localStorage.setItem(\"ONE_NETWORK\", Crypt({ Type: \"crypt\", Value: JSON.stringify(res.data) }))\n            setReady({ ...ready, load: false })\n          }\n        })\n      }\n    } catch (error) {\n      toast_error({ text: \"ກະລຸນາປ້ອນເບີ !!\" })\n      history.push(\"/app\")\n    }\n  }, [])\n  return (\n    <>\n      <Grid container>\n        <Grid item xs={12} md={6}>\n          <Col1 />\n        </Grid>\n        <Grid item xs={12} md={6}>\n          <Col2 />\n        </Grid>\n      </Grid>\n    </>\n  )\n}\n\nexport default CRM","/Users/joebest/Desktop/Github/1Screen/src/Pages/App/Home/Home.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Components/Crypt.js",[],"/Users/joebest/Desktop/Github/1Screen/src/Components/Auth.js",[],"/Users/joebest/Desktop/Github/1Screen/src/Components/ProtectRoute.js",[],"/Users/joebest/Desktop/Github/1Screen/src/Components/LoadingLottie.js",[],"/Users/joebest/Desktop/Github/1Screen/src/Components/Axios.js",[],"/Users/joebest/Desktop/Github/1Screen/src/Components/MyCrypt.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Components/AutoFC.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/User/User.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/User/UserTab.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/User/UserEdit.jsx",["168"],"import { CheckBox, Save } from '@mui/icons-material'\nimport { Button, CircularProgress, Grid, TextField } from '@mui/material'\nimport React from 'react'\nimport { MyCrypt } from '../../../Components/MyCrypt'\nimport FadeIn from 'react-fade-in/lib/FadeIn'\nimport { UserID } from '../../../Components/AutoFC'\nimport { AxiosAPI } from '../../../Components/Axios'\nimport { toast_error, toast_success } from '../../../Components/Toast'\n\nfunction UserEdit() {\n    const [top, setTop] = React.useState({ data: [] })\n    const [loading, setLoading] = React.useState({ btn: false, data: false })\n\n    const loadTop = () => {\n        setLoading({ ...loading, data: false })\n        let data = MyCrypt(\"de\", localStorage.getItem(\"ONE_USER_ROLE\"))\n        let new_data = data?.map(row => {\n            row.password = row.Password === null || row.Password === '' ? '' : MyCrypt(\"de\", row.Password)\n            row.Username = row.Username === 'null' || row.Username === null ? '' : row.Username\n            return row\n        })\n        setTop({ ...top, data: new_data })\n        setLoading({ ...loading, data: true })\n    }\n\n    React.useEffect(() => {\n        loadTop()\n    }, [])\n\n    const Change = (value, id, type) => {\n        if (type === 'username') {\n            let new_data = top.data.map(row => {\n                if (row.ID === id) {\n                    row.Username = value\n                }\n                return row\n            })\n            setTop({ ...top, data: new_data })\n        } else {\n            let new_data = top.data.map(row => {\n                if (row.ID === id) {\n                    row.Password = MyCrypt(\"en\", JSON.stringify(value))\n                    row.password = value\n                }\n                return row\n            })\n            setTop({ ...top, data: new_data })\n        }\n    }\n\n    const SaveUserRole = () => {\n        setLoading({ ...loading, btn: true })\n        localStorage.setItem(\"ONE_USER_ROLE\", MyCrypt(\"en\", JSON.stringify(top.data)))\n        try {\n            let s_data = top.data.map(row => {\n                delete row.password\n                return row\n            })\n            let sendData = {\n                staff_id: UserID(),\n                users: s_data\n            }\n            AxiosAPI.post(\"insert-user\", sendData).then(res => {\n                if (res.status === 200) {\n                    setTimeout(() => {\n                        setLoading({ ...loading, btn: false })\n                        toast_success({ text: res.data.message })\n                    }, 500)\n                }\n            }).catch(er => {\n                setTimeout(() => {\n                    setLoading({ ...loading, btn: false })\n                    toast_error({ text: \"API Error\" })\n                }, 1000)\n            })\n        } catch (error) {\n\n        }\n    }\n\n    return (\n        <FadeIn>\n            <Grid container>\n                {loading.data && top.data?.map((row, idx) => {\n                    return (\n                        <Grid item lg={6} xs={12} key={idx}>\n                            <div className=\"padd\">\n                                <CheckBox color='primary' style={{ marginTop: 5 }} /> &nbsp;&nbsp;\n                                <u>{row.Name}</u>\n                            </div>\n                            <Grid container spacing={2} item xs={12}>\n                                <Grid item xs={6}>\n                                    <div className='textInput'>\n                                        <TextField\n                                            fullWidth\n                                            variant='standard'\n                                            margin='dense'\n                                            color='primary'\n                                            label={\"username ( \" + row.Name + \" )\"}\n                                            InputLabelProps={{\n                                                shrink: true\n                                            }}\n                                            value={top.data[idx].Username}\n                                            onChange={(e) => Change(e.target.value, row.ID, \"username\")}\n                                        />\n                                    </div>\n                                </Grid>\n                                <Grid item xs={6}>\n                                    <div className='textInput'>\n                                        <TextField\n                                            fullWidth\n                                            variant='standard'\n                                            color='primary'\n                                            margin='dense'\n                                            label={\"password ( \" + row.Name + \" )\"}\n                                            // type={\"password\"}\n                                            InputLabelProps={{\n                                                shrink: true\n                                            }}\n                                            value={top.data[idx].password}\n                                            onChange={(e) => Change(e.target.value, row.ID, \"password\")}\n                                        />\n                                    </div>\n                                </Grid>\n                            </Grid>\n                        </Grid>\n                    )\n                })}\n                <Grid item xs={12}>\n                    {loading.data && <>\n                        <div style={{ marginTop: 20, marginBottom: 30, textAlign: 'right', paddingRight: 30 }}>\n                            <Button\n                                variant='contained'\n                                color='success'\n                                onClick={SaveUserRole}\n                                disabled={loading.btn}\n                            >\n                                {loading.btn ? <CircularProgress size={25} /> : <>ບັນທຶກ <Save /></>}\n                            </Button>\n                        </div>\n                    </>}\n                </Grid>\n            </Grid>\n        </FadeIn>\n    )\n}\n\nexport default UserEdit","/Users/joebest/Desktop/Github/1Screen/src/Components/MenuBar.jsx",["169"],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/SearchCRM.jsx",["170"],"import { Phone, Search } from '@mui/icons-material'\nimport { Button, Grid } from '@mui/material'\nimport React, { useEffect } from 'react'\nimport { useState } from 'react'\nimport { useHistory } from 'react-router-dom'\nimport { toast_error } from '../../Components/Toast'\n\nfunction SearchCRM() {\n    const [Phone, setPhone] = useState('')\n    const history = useHistory()\n    useEffect(() => {\n        try {\n            let p = localStorage.getItem(\"ONE_PHONE\")\n            setPhone(p)\n        } catch (error) {\n            setPhone(\"\")\n        }\n    }, [])\n    const changePhone = (e) => {\n        if (e.length > 10) {\n            let number = e.replaceAll(/\\s/g, '')\n            let newPhone = ''\n            if (number.includes(\"+85620\")) {\n                newPhone = String(number).substring(4, 14)\n            } else if (number.includes(\"20\")) {\n                newPhone = number\n            }\n\n            if (newPhone.length === 10) {\n                setPhone(newPhone)\n                // setNbad({ ...nbad, fc: false })\n            }\n        } else {\n            setPhone(e)\n            // setNbad({ ...nbad, fc: false })\n        }\n    }\n    const searchPhoneNumber = () => {\n        if (Phone === '' || Phone === null) {\n            toast_error({ text: \"ກະລຸນາປ້ອນເບີ !!\" })\n        } else {\n            localStorage.setItem(\"ONE_PHONE\", Phone)\n            history.push(\"/app\")\n            setTimeout(() => {\n                history.push(\"/app/crm\")\n            }, 100)\n        }\n    }\n    const checkKey = (e) => {\n        if (e.code === 'Enter' || e.code === 'NumpadEnter') {\n            searchPhoneNumber()\n        }\n    }\n    return (\n        <Grid container className='search'>\n            <Grid item xs={4} lg={8}></Grid>\n            <Grid item xs={5} lg={2}>\n                <input\n                    type={\"search\"}\n                    maxLength=\"10\"\n                    className='v-input input-1'\n                    placeholder='205xxxxxxx'\n                    value={Phone}\n                    onChange={(e) => changePhone(e.target.value)}\n                    onKeyPress={(e) => checkKey(e)}\n                />\n            </Grid>\n            <Grid item xs={2} lg={1}>\n                <Button\n                    variant='contained'\n                    className='btn-primary'\n                    style={{ marginLeft: 5, marginTop: 5 }}\n                    onClick={searchPhoneNumber}\n                >\n                    <Search />\n                </Button>\n            </Grid>\n        </Grid>\n    )\n}\n\nexport default SearchCRM","/Users/joebest/Desktop/Github/1Screen/src/Components/Toast.js",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/CRM/Col1.jsx",["171","172","173"],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/CRM/Col2.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/CRM/Col1/Balance.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/CRM/Col1/Network.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/CRM/Col1/LifeCycle.jsx",["174","175","176","177"],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/CRM/Col1/3grab/Register3Grab.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Components/GetPhoneNumber.js",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/CRM/Col1/Bss/BssRegister.jsx",["178"],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/CRM/Col1/BlackList/BlackList.jsx",["179","180"],"/Users/joebest/Desktop/Github/1Screen/src/Components/LoadLottie.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/CRM/Col1/MobileService/MobileService.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/CRM/Col1/InerService/InterService.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/CRM/Col2/BillQuery/BillQuery.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/CRM/Col2/BillQuery/DateBillQuery.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/CRM/Col2/Packge/Packages.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/CRM/Col2/Banking/Banking.jsx",["181"],{"ruleId":"182","replacedBy":"183"},{"ruleId":"184","replacedBy":"185"},{"ruleId":"186","severity":1,"message":"187","line":16,"column":8,"nodeType":"188","endLine":16,"endColumn":10,"suggestions":"189"},{"ruleId":"190","severity":1,"message":"191","line":180,"column":17,"nodeType":"192","endLine":180,"endColumn":131},{"ruleId":"186","severity":1,"message":"193","line":34,"column":6,"nodeType":"188","endLine":34,"endColumn":8,"suggestions":"194"},{"ruleId":"186","severity":1,"message":"195","line":28,"column":8,"nodeType":"188","endLine":28,"endColumn":10,"suggestions":"196"},{"ruleId":"197","severity":1,"message":"198","line":3,"column":8,"nodeType":"199","messageId":"200","endLine":3,"endColumn":18},{"ruleId":"197","severity":1,"message":"201","line":1,"column":10,"nodeType":"199","messageId":"200","endLine":1,"endColumn":15},{"ruleId":"197","severity":1,"message":"202","line":3,"column":16,"nodeType":"199","messageId":"200","endLine":3,"endColu