t\" className='link-btn list' value={name} />\n                </form>\n            </>\n        } else {\n            return <>{name}</>\n        }\n    }\n\n    return (\n        <>\n            <div className='frame'>\n                {topData.data.map((row, idx) => {\n                    return (\n                        <div className={idx === 0 ? 'list' : 'list'} key={idx}><FadeIn>\n                            <LinkList id={row.ID} name={row.Name} />\n                        </FadeIn></div>\n                    )\n                })}\n            </div>\n        </>\n    )\n}\n\nexport default TopBar","/Users/joebest/Desktop/Github/1Screen/src/Pages/App/Router.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/CRM/CRM.jsx",["121"],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/Home/Home.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Components/Crypt.js",[],"/Users/joebest/Desktop/Github/1Screen/src/Components/Auth.js",[],"/Users/joebest/Desktop/Github/1Screen/src/Components/ProtectRoute.js",[],"/Users/joebest/Desktop/Github/1Screen/src/Components/LoadingLottie.js",[],"/Users/joebest/Desktop/Github/1Screen/src/Components/Axios.js",[],"/Users/joebest/Desktop/Github/1Screen/src/Components/MyCrypt.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Components/AutoFC.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/User/User.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/User/UserTab.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/User/UserEdit.jsx",["122"],"import { CheckBox, Save } from '@mui/icons-material'\nimport { Button, CircularProgress, Grid, TextField } from '@mui/material'\nimport React from 'react'\nimport { MyCrypt } from '../../../Components/MyCrypt'\nimport FadeIn from 'react-fade-in/lib/FadeIn'\nimport { UserID } from '../../../Components/AutoFC'\nimport { AxiosAPI } from '../../../Components/Axios'\nimport { toast_error, toast_success } from '../../../Components/Toast'\n\nfunction UserEdit() {\n    const [top, setTop] = React.useState({ data: [] })\n    const [loading, setLoading] = React.useState({ btn: false, data: false })\n\n    const loadTop = () => {\n        setLoading({ ...loading, data: false })\n        let data = MyCrypt(\"de\", localStorage.getItem(\"ONE_USER_ROLE\"))\n        let new_data = data?.map(row => {\n            row.password = row.Password === null || row.Password === '' ? '' : MyCrypt(\"de\", row.Password)\n            row.Username = row.Username === 'null' || row.Username === null ? '' : row.Username\n            return row\n        })\n        setTop({ ...top, data: new_data })\n        setLoading({ ...loading, data: true })\n    }\n\n    React.useEffect(() => {\n        loadTop()\n    }, [])\n\n    const Change = (value, id, type) => {\n        if (type === 'username') {\n            let new_data = top.data.map(row => {\n                if (row.ID === id) {\n                    row.Username = value\n                }\n                return row\n            })\n            setTop({ ...top, data: new_data })\n        } else {\n            let new_data = top.data.map(row => {\n                if (row.ID === id) {\n                    row.Password = MyCrypt(\"en\", JSON.stringify(value))\n                    row.password = value\n                }\n                return row\n            })\n            setTop({ ...top, data: new_data })\n        }\n    }\n\n    const SaveUserRole = () => {\n        setLoading({ ...loading, btn: true })\n        localStorage.setItem(\"ONE_USER_ROLE\", MyCrypt(\"en\", JSON.stringify(top.data)))\n        try {\n            let s_data = top.data.map(row => {\n                delete row.password\n                return row\n            })\n            let sendData = {\n                staff_id: UserID(),\n                users: s_data\n            }\n            AxiosAPI.post(\"insert-user\", sendData).then(res => {\n                if (res.status === 200) {\n                    setTimeout(() => {\n                        setLoading({ ...loading, btn: false })\n                        toast_success({ text: res.data.message })\n                    }, 500)\n                }\n            }).catch(er => {\n                setTimeout(() => {\n                    setLoading({ ...loading, btn: false })\n                    toast_error({ text: \"API Error\" })\n                }, 1000)\n            })\n        } catch (error) {\n\n        }\n    }\n\n    return (\n        <FadeIn>\n            <Grid container>\n                {loading.data && top.data?.map((row, idx) => {\n                    return (\n                        <Grid item lg={6} xs={12} key={idx}>\n                            <div className=\"padd\">\n                                <CheckBox color='primary' style={{ marginTop: 5 }} /> &nbsp;&nbsp;\n                                <u>{row.Name}</u>\n                            </div>\n                            <Grid container spacing={2} item xs={12}>\n                                <Grid item xs={6}>\n                                    <div className='textInput'>\n                                        <TextField\n                                            fullWidth\n                                            variant='standard'\n                                            margin='dense'\n                                            color='primary'\n                                            label={\"username ( \" + row.Name + \" )\"}\n                                            InputLabelProps={{\n                                                shrink: true\n                                            }}\n                                            value={top.data[idx].Username}\n                                            onChange={(e) => Change(e.target.value, row.ID, \"username\")}\n                                        />\n                                    </div>\n                                </Grid>\n                                <Grid item xs={6}>\n                                    <div className='textInput'>\n                                        <TextField\n                                            fullWidth\n                                            variant='standard'\n                                            color='primary'\n                                            margin='dense'\n                                            label={\"password ( \" + row.Name + \" )\"}\n                                            // type={\"password\"}\n                                            InputLabelProps={{\n                                                shrink: true\n                                            }}\n                                            value={top.data[idx].password}\n                                            onChange={(e) => Change(e.target.value, row.ID, \"password\")}\n                                        />\n                                    </div>\n                                </Grid>\n                            </Grid>\n                        </Grid>\n                    )\n                })}\n                <Grid item xs={12}>\n                    {loading.data && <>\n                        <div style={{ marginTop: 20, marginBottom: 30, textAlign: 'right', paddingRight: 30 }}>\n                            <Button\n                                variant='contained'\n                                color='success'\n                                onClick={SaveUserRole}\n                                disabled={loading.btn}\n                            >\n                                {loading.btn ? <CircularProgress size={25} /> : <>ບັນທຶກ <Save /></>}\n                            </Button>\n                        </div>\n                    </>}\n                </Grid>\n            </Grid>\n        </FadeIn>\n    )\n}\n\nexport default UserEdit","/Users/joebest/Desktop/Github/1Screen/src/Components/MenuBar.jsx",["123"],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/SearchCRM.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Components/Toast.js",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/CRM/Col1.jsx",["124","125","126"],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/CRM/Col2.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/CRM/Col1/Balance.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/CRM/Col1/Network.jsx",[],"/Users/joebest/Desktop/Github/1Screen/src/Pages/App/CRM/Col1/LifeCycle.jsx",["127","128"],{"ruleId":"129","replacedBy":"130"},{"ruleId":"131","replacedBy":"132"},{"ruleId":"133","severity":1,"message":"134","line":16,"column":8,"nodeType":"135","endLine":16,"endColumn":10,"suggestions":"136"},{"ruleId":"137","severity":1,"message":"138","line":180,"column":17,"nodeType":"139","endLine":180,"endColumn":131},{"ruleId":"133","severity":1,"message":"140","line":41,"column":6,"nodeType":"135","endLine":41,"endColumn":8,"suggestions":"141"},{"ruleId":"133","severity":1,"message":"142","line":28,"column":8,"nodeType":"135","endLine":28,"endColumn":10,"suggestions":"143"},{"ruleId":"144","severity":1,"message":"145","line":3,"column":8,"nodeType":"146","messageId":"147","endLine":3,"endColumn":18},{"ruleId":"144","severity":1,"message":"148","line":4,"column":27,"nodeType":"146","messageId":"147","endLine":4,"endColumn":36},{"ruleId":"144","severity":1,"message":"149","line":5,"column":10,"nodeType":"146","messageId":"147","endLine":5,"endColumn":18},{"ruleId":"144","severity":1,"message":"150","line":6,"column":10,"nodeType":"146","messageId":"147","endLine":6,"endColumn":17},{"ruleId":"144","severity":1,"message":"151","line":1,"column":10,"nodeType":"146","messageId":"147","endLine":1,"endColumn":15},{"ruleId":"133","severity":1,"message":"152","line":29,"column":8,"nodeType":"135","endLine":29,"endColumn":10,"suggestions":"153"},"no-native-reassign",["154"],"no-negated-in-lhs",["155"],"react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'loadTopMenu'. Either include it or remove the dependency array.","ArrayExpression",["156"],"jsx-a11y/no-redundant-roles","The element form has an implicit role of form. Defining this explicitly is redundant and should be avoided.","JSXOpeningElement","React Hook useEffect has a missing dependency: 'ready'. Either include it or remove the dependency array. You can also do a functional update 'setReady(r => ...)' if you only need 'ready' in the 'setReady' call.",["157"],"React Hook React.useEffect has a missing dependency: 'loadTop'. Either include it or remove the dependency array.",["158"],"no-unused-vars","'Typography' is defined but never used.","Identifier","unusedVar","'useEffect' is defined but never used.","'AxiosReq' is defined but never used.","'MyCrypt' is defined but never used.","'Check' is defined but never used.","React Hook useEffect has a missing dependency: 'date'. Either include it or remove the dependency array. You can also do a functional update 'setDate(d => ...)' if you only need 'date' in the 'setDate' call.",["159"],"no-global-assign","no-unsafe-negation",{"desc":"160","fix":"161"},{"desc":"162","fix":"163"},{"desc":"164","fix":"165"},{"desc":"166","fix":"167"},"Update the dependencies array to be: [loadTopMenu]",{"range":"168","text":"169"},"Update the dependencies array to be: [ready]",{"range":"170","text":"171"},"Update the dependencies array to be: [loadTop]",{"range":"172","text":"173"},"Update the dependencies array to be: [date]",{"range":"174","text":"175"},[465,467],"[loadTopMenu]",[1396,1398],"[ready]",[1163,1165],"[loadTop]",[1628,1630],"[date]"]